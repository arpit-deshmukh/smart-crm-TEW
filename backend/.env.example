PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/smartcrm
SESSION_SECRET=your_super_secret_session_key
GOOGLE_CLIENT_ID=your_google_client_id_here

# Mail Config (Nodemailer for password resets etc.)
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# Mailjet Config (Admin Emails)
MAILJET_API_KEY=your_mailjet_api_key_here
MAILJET_SECRET_KEY=your_mailjet_secret_key_here
MAILJET_SENDER_EMAIL=your_verified_sender_email@domain.com

# N8N Webhooks (Lead & Followup Automations)
N8N_LEAD_MAIL_WEBHOOK_URL=https://your-n8n-instance.com/webhook/lead
N8N_FOLLOWUP_MAIL_WEBHOOK_URL=https://your-n8n-instance.com/webhook/followup
